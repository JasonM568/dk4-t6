// 線上課程學習網站 — 資料模型（course schema 版）
// 金額一律用整數（新台幣元）。
// 會員身分在 Supabase auth.users（uuid），本 schema 不存任何密碼/帳號資料。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")          // …?schema=course（runtime，Supabase 走 6543 pooler）
  directUrl = env("DATABASE_URL_UNPOOLED") // …?schema=course（migrate 用，Supabase 必須 5432 direct）
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ── 會員統計（取代原 User 上的等級狀態欄位）──
// userId = Supabase auth.users.id（uuid）。lazy upsert：首次下單/付款時建立。
// 不建 FK：auth.users 在 auth schema，本機開發 PG 沒有該 schema。
model MemberStats {
  userId        String          @id @db.Uuid
  currentTierId String?
  currentTier   MembershipTier? @relation(fields: [currentTierId], references: [id])
  totalSpent    Int             @default(0) // 累積實付金額
  coursesBought Int             @default(0) // 累積購課數

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 管理員設定的會員初始密碼備查（僅後台顯示）。
// 注意：這不是 Auth 的真實密碼（Auth 只存雜湊不可逆）；學員自行改密碼後此表不會同步
model MemberPassword {
  userId    String   @id @db.Uuid
  password  String
  updatedBy String? // 設定的管理員 email
  updatedAt DateTime @updatedAt
}

// course 平台自管的後台幹部角色（admin 仍沿用 QBC public.profiles.role=admin，不存這裡）。
// OPERATOR=操作人員（可查看+編輯+匯出+批次/群發）；COACH=總教練（只能查看訂單/課程/會員）。
// userId = auth.users.id；email 為指派當下快照，純顯示用。
model StaffRole {
  userId    String   @id @db.Uuid
  role      String // OPERATOR | COACH
  email     String? // 指派當下 email 快照（權限管理頁顯示用）
  assignedBy String? // 指派的管理員 email
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 等級門檻設定表（後台可調）
model MembershipTier {
  id               String @id @default(cuid())
  name             String // 銅 / 銀 / 金
  level            Int    @unique // 0,1,2,3…（用於排序與比較）
  minTotalSpent    Int    @default(0) // 升級門檻：累積消費
  minCoursesBought Int    @default(0) // 升級門檻：購課數（與上者並用，須同時達標）
  discountPercent  Int    @default(0) // 折扣 %（0-100）

  members MemberStats[]
}

// 站台設定（key-value）：目前用於前台分頁開關（page:<key> = "on"/"off"，無資料列視為開啟）
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// 群發通知/電子報：立即寄出的歷史紀錄＋排程待寄
// status：SCHEDULED（排程待寄）/ SENDING（cron 處理中）/ SENT / CANCELED / FAILED
// audienceType：ALL（全部會員）/ GROUP（名單群組）/ MANUAL（手動貼名單）
model EmailBroadcast {
  id            String    @id @default(cuid())
  subject       String
  body          String    @db.Text
  courseId      String? // 關聯課程（選填，信中帶課程連結）
  sentCount     Int       @default(0)
  failedCount   Int       @default(0)
  sentBy        String? // 操作的管理員 email
  status        String    @default("SENT")
  scheduledAt   DateTime? // 預設發送時間（null = 立即寄出）
  sentAt        DateTime? // 實際寄出時間
  audienceType  String    @default("ALL")
  groupId       String? // audienceType=GROUP 時的群組（寄出當下取最新成員）
  audienceLabel String? // 顯示用：全部會員 / 群組：xxx / 手動名單 N 筆
  manualRows    Json? // audienceType=MANUAL 時的名單 [{email,name}]
  recipients    String[]  @default([]) // 實際寄出名單快照（供事後存成群組）
  claimedAt     DateTime? // 進入 SENDING（cron 認領）的時間；用於回收逾時卡死的寄送

  createdAt DateTime @default(now())
}

// 電子報名單群組
model MailGroup {
  id      String            @id @default(cuid())
  name    String            @unique
  members MailGroupMember[]

  createdAt DateTime @default(now())
}

model MailGroupMember {
  id      String    @id @default(cuid())
  groupId String
  group   MailGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  email   String
  name    String?

  createdAt DateTime @default(now())

  @@unique([groupId, email]) // 群組內 email 唯一，重複加入自動略過
  @@index([groupId])
}

// ── 企業專區（世華會等企業包班）──
// 課程掛 groupId 後即從公開型錄（/courses、首頁、checkout）隱藏，
// 僅專區會員（CourseGroupMember，以 email 比對）與後台幹部可見。
// 觀看權限仍走 Enrollment（逐課開通），專區只管「可見性」。
model CourseGroup {
  id           String  @id @default(cuid())
  slug         String  @unique // 前台路由 /zone/<slug>（如 shihua）
  name         String // 顯示名稱（如 世華會學習專區）
  wallText     String? @db.Text // 非會員擋牆頁的說明文字（選填，如聯絡窗口）
  isActive     Boolean @default(true) // 停用 = 前台整區 404
  themePrimary String? // 專區主題色 #RRGGBB（標題區/按鈕）；空 = 全站預設靛藍
  themeAccent  String? // 輔助色 #RRGGBB（漸層第二色/徽章）；空 = 沿用主題色

  courses     Course[]
  members     CourseGroupMember[]
  inviteCodes GroupInviteCode[]

  createdAt DateTime @default(now())
}

// 專區會員：以 email 為鍵（存入前一律 toLowerCase().trim()），
// 允許尚未註冊的 email 先入名單；userId 已知時回填，純稽核用。
model CourseGroupMember {
  id      String      @id @default(cuid())
  groupId String
  group   CourseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  email   String
  name    String?
  userId  String?     @db.Uuid // auth.users.id，已知時回填
  source  String // MANUAL | IMPORT | INVITE
  addedBy String? // 操作管理員 email 或邀請碼 code

  createdAt DateTime @default(now())

  @@unique([groupId, email]) // 群組內 email 唯一，重複匯入自動略過
  @@index([groupId])
  @@index([email])
}

// 專區邀請碼：註冊頁帶 ?invite=CODE 或擋牆頁輸入即取得會籍。
// usedCount 純統計非上限；要停止發放就 isActive=false 或換碼。
model GroupInviteCode {
  id        String      @id @default(cuid())
  groupId   String
  group     CourseGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  code      String      @unique // 8 碼易讀隨機（去 0/O/1/I），比對時 uppercase
  label     String? // 備註（如 2026 年會發放）
  isActive  Boolean     @default(true)
  expiresAt DateTime? // null = 不限期
  usedCount Int         @default(0)
  createdBy String? // 產碼的管理員 email

  createdAt DateTime @default(now())
}

// 課程分類（後台自行維護選項，課程可勾選多個分類）
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  courses   Course[]

  createdAt DateTime @default(now())
}

model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  courseCode  String?  @unique // 課程編號（如 HA-001，選填）
  title       String
  description String   @db.Text
  coverImage  String?
  introImages String[] @default([]) // 課程介紹圖（詳情頁描述下方依序顯示）
  listPrice   Int? // 建議售價（僅展示用，前台劃線價；空 = 不顯示）
  price       Int // 優惠價 = 實際售價（新台幣整數，金流以此計算）
  sortOrder   Int      @default(0) // 前台顯示順序（小的在前，後台上移/下移調整）
  isPublished Boolean  @default(false)
  groupId     String? // 所屬企業專區；null = 一般公開販售課程
  group       CourseGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  lessons     Lesson[]
  materials   CourseMaterial[]
  categories  Category[]
  orderItems  OrderItem[]
  enrollments Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
}

model Lesson {
  id          String  @id @default(cuid())
  courseId    String
  course      Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  youtubeId   String // 只存 YouTube video id，播放頁才組成 embed
  slideUrl    String? // 線上簡報嵌入網址（Google Slides/Canva），播放頁影片下方顯示
  order       Int
  durationSec Int?

  @@index([courseId])
}

// 課程講義（下載檔案，存 Supabase Storage 或外部網址）
model CourseMaterial {
  id       String @id @default(cuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  url      String

  createdAt DateTime @default(now())

  @@index([courseId])
}

model Order {
  id          String      @id @default(cuid())
  orderNo     String      @unique // ECPay MerchantTradeNo（≤20 字元）
  userId      String      @db.Uuid // auth.users.id，無 FK
  buyerEmail  String? // 下單當下 email 快照（後台顯示與稽核用）
  status      OrderStatus @default(PENDING)
  subtotal    Int // 折扣前總額
  discount    Int         @default(0) // 套用的折扣金額
  total       Int // 實付 = subtotal - discount
  tierAtOrder Int? // 下單當下等級 level（稽核用）

  items   OrderItem[]
  payment Payment?

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  @@index([userId])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course @relation(fields: [courseId], references: [id])
  unitPrice Int // 下單當下價格快照

  @@unique([orderId, courseId])
  @@index([courseId])
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id])
  provider    String // "ecpay" | "newebpay"
  status      PaymentStatus @default(PENDING)
  amount      Int
  tradeNo     String? // 金流商交易序號（回傳）
  paymentType String? // Credit / ATM / CVS…
  rawCallback Json? // 完整 callback 存證
  notifiedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 已購買關係 — 「能不能看課程」的唯一真實來源
model Enrollment {
  id       String  @id @default(cuid())
  userId   String  @db.Uuid // auth.users.id，無 FK
  courseId String
  course   Course  @relation(fields: [courseId], references: [id])
  orderId  String? // 來源訂單
  source   String? // 開通來源：PURCHASE/MANUAL/BATCH/IMPORT（null=歷史資料，顯示時依 orderId 推斷）

  createdAt DateTime @default(now())

  @@unique([userId, courseId]) // 防重複授權，並保證 webhook 冪等
  @@index([userId])
}
