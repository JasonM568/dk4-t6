// 線上課程學習網站 — 資料模型（course schema 版）
// 金額一律用整數（新台幣元）。
// 會員身分在 Supabase auth.users（uuid），本 schema 不存任何密碼/帳號資料。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")          // …?schema=course（runtime，Supabase 走 6543 pooler）
  directUrl = env("DATABASE_URL_UNPOOLED") // …?schema=course（migrate 用，Supabase 必須 5432 direct）
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ── 會員統計（取代原 User 上的等級狀態欄位）──
// userId = Supabase auth.users.id（uuid）。lazy upsert：首次下單/付款時建立。
// 不建 FK：auth.users 在 auth schema，本機開發 PG 沒有該 schema。
model MemberStats {
  userId        String          @id @db.Uuid
  currentTierId String?
  currentTier   MembershipTier? @relation(fields: [currentTierId], references: [id])
  totalSpent    Int             @default(0) // 累積實付金額
  coursesBought Int             @default(0) // 累積購課數

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 等級門檻設定表（後台可調）
model MembershipTier {
  id               String @id @default(cuid())
  name             String // 銅 / 銀 / 金
  level            Int    @unique // 0,1,2,3…（用於排序與比較）
  minTotalSpent    Int    @default(0) // 升級門檻：累積消費
  minCoursesBought Int    @default(0) // 升級門檻：購課數（與上者並用，須同時達標）
  discountPercent  Int    @default(0) // 折扣 %（0-100）

  members MemberStats[]
}

// 站台設定（key-value）：目前用於前台分頁開關（page:<key> = "on"/"off"，無資料列視為開啟）
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// 群發通知/電子報：立即寄出的歷史紀錄＋排程待寄
// status：SCHEDULED（排程待寄）/ SENDING（cron 處理中）/ SENT / CANCELED / FAILED
// audienceType：ALL（全部會員）/ GROUP（名單群組）/ MANUAL（手動貼名單）
model EmailBroadcast {
  id            String    @id @default(cuid())
  subject       String
  body          String    @db.Text
  courseId      String? // 關聯課程（選填，信中帶課程連結）
  sentCount     Int       @default(0)
  failedCount   Int       @default(0)
  sentBy        String? // 操作的管理員 email
  status        String    @default("SENT")
  scheduledAt   DateTime? // 預設發送時間（null = 立即寄出）
  sentAt        DateTime? // 實際寄出時間
  audienceType  String    @default("ALL")
  groupId       String? // audienceType=GROUP 時的群組（寄出當下取最新成員）
  audienceLabel String? // 顯示用：全部會員 / 群組：xxx / 手動名單 N 筆
  manualRows    Json? // audienceType=MANUAL 時的名單 [{email,name}]
  recipients    String[]  @default([]) // 實際寄出名單快照（供事後存成群組）

  createdAt DateTime @default(now())
}

// 電子報名單群組
model MailGroup {
  id      String            @id @default(cuid())
  name    String            @unique
  members MailGroupMember[]

  createdAt DateTime @default(now())
}

model MailGroupMember {
  id      String    @id @default(cuid())
  groupId String
  group   MailGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  email   String
  name    String?

  createdAt DateTime @default(now())

  @@unique([groupId, email]) // 群組內 email 唯一，重複加入自動略過
  @@index([groupId])
}

// 課程分類（後台自行維護選項，課程可勾選多個分類）
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  courses   Course[]

  createdAt DateTime @default(now())
}

model Course {
  id          String   @id @default(cuid())
  slug        String   @unique
  courseCode  String?  @unique // 課程編號（如 HA-001，選填）
  title       String
  description String   @db.Text
  coverImage  String?
  introImages String[] @default([]) // 課程介紹圖（詳情頁描述下方依序顯示）
  listPrice   Int? // 建議售價（僅展示用，前台劃線價；空 = 不顯示）
  price       Int // 優惠價 = 實際售價（新台幣整數，金流以此計算）
  sortOrder   Int      @default(0) // 前台顯示順序（小的在前，後台上移/下移調整）
  isPublished Boolean  @default(false)

  lessons     Lesson[]
  materials   CourseMaterial[]
  categories  Category[]
  orderItems  OrderItem[]
  enrollments Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lesson {
  id          String  @id @default(cuid())
  courseId    String
  course      Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  youtubeId   String // 只存 YouTube video id，播放頁才組成 embed
  slideUrl    String? // 線上簡報嵌入網址（Google Slides/Canva），播放頁影片下方顯示
  order       Int
  durationSec Int?

  @@index([courseId])
}

// 課程講義（下載檔案，存 Supabase Storage 或外部網址）
model CourseMaterial {
  id       String @id @default(cuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  url      String

  createdAt DateTime @default(now())

  @@index([courseId])
}

model Order {
  id          String      @id @default(cuid())
  orderNo     String      @unique // ECPay MerchantTradeNo（≤20 字元）
  userId      String      @db.Uuid // auth.users.id，無 FK
  buyerEmail  String? // 下單當下 email 快照（後台顯示與稽核用）
  status      OrderStatus @default(PENDING)
  subtotal    Int // 折扣前總額
  discount    Int         @default(0) // 套用的折扣金額
  total       Int // 實付 = subtotal - discount
  tierAtOrder Int? // 下單當下等級 level（稽核用）

  items   OrderItem[]
  payment Payment?

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  @@index([userId])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course @relation(fields: [courseId], references: [id])
  unitPrice Int // 下單當下價格快照

  @@unique([orderId, courseId])
  @@index([courseId])
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id])
  provider    String // "ecpay" | "newebpay"
  status      PaymentStatus @default(PENDING)
  amount      Int
  tradeNo     String? // 金流商交易序號（回傳）
  paymentType String? // Credit / ATM / CVS…
  rawCallback Json? // 完整 callback 存證
  notifiedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 已購買關係 — 「能不能看課程」的唯一真實來源
model Enrollment {
  id       String  @id @default(cuid())
  userId   String  @db.Uuid // auth.users.id，無 FK
  courseId String
  course   Course  @relation(fields: [courseId], references: [id])
  orderId  String? // 來源訂單

  createdAt DateTime @default(now())

  @@unique([userId, courseId]) // 防重複授權，並保證 webhook 冪等
  @@index([userId])
}
